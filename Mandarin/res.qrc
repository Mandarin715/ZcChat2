<RCC>
    <qresource prefix="/">
        <file>res/img/ico/camera-solid.svg</file>
        <file>res/img/ico/log-24.svg</file>
        <file>res/img/ico/microphone-solid.svg</file>
        <file>res/img/ico/github-mark.svg</file>
        <file>res/img/ico/circle-dot-regular.svg</file>
        <file>res/img/ico/file-solid.svg</file>
        <file>res/img/ico/turn-back.svg</file>
        <file>res/img/logo/logo.png</file>
    </qresource>
    <qresource prefix="/default_config">
        <file alias="Mandarin/config.ini">res/default_config/Mandarin/config.ini</file>
        <file alias="Mandarin/Plugin/Anime/Basic Animation Package.json">res/default_config/Mandarin/Plugin/Anime/Basic Animation Package.json</file>
        <file alias="Mandarin/Character/Assets/test/config.json">res/default_config/Mandarin/Character/Assets/test/config.json</file>
        <file alias="Mandarin/Character/Assets/test/Tachie/default.png">res/default_config/Mandarin/Character/Assets/test/Tachie/default.png</file>
        <file alias="Mandarin/Character/UserConfig/test/config.json">res/default_config/Mandarin/Character/UserConfig/test/config.json</file>
    </qresource>
</RCC>
